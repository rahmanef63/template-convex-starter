# Convex deployment URL ("cloud") — your *.convex.cloud address, used by the
# browser client. SET IN VERCEL. Locally, `npx convex dev` writes it here.
NEXT_PUBLIC_CONVEX_URL=

# Production deploy key ("deploy key") from Convex (Settings -> Deploy Keys).
# SET IN VERCEL. The build (build:auto) uses it to push functions+schema to
# Convex and to auto-provision the auth keys below.
CONVEX_DEPLOY_KEY=

# Convex HTTP/site URL ("site") — your *.convex.site address, serves JWKS/auth.
# AUTO on Convex Cloud (derived from your deployment); only set it manually if
# you run a self-hosted backend.
CONVEX_SITE_URL=

# App public URL ("domain") — where auth redirects land. AUTO-derived from
# VERCEL_URL by scripts/setup-auth.mjs during build. For local dev use below.
SITE_URL=http://localhost:3000

# @convex-dev/auth signing keys. AUTO-SET during build by scripts/setup-auth.mjs
# when CONVEX_DEPLOY_KEY is present (you usually don't touch these). Listed here
# for local dev / manual fallback.
JWKS=
JWT_PRIVATE_KEY=

# OPTIONAL — Claude API key for the built-in AI assistant (/assistant). The app
# runs fine without it; the assistant just stays offline until this is set.
# Get one at https://console.anthropic.com. Server-only — never NEXT_PUBLIC_.
ANTHROPIC_API_KEY=
